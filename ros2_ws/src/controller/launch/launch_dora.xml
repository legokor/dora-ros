<?xml version="1.0" encoding="UTF-8"?>
<launch>
  <node pkg="controller" exec="controller" name="controller" namespace="dora" />

  <include file="$(find-pkg-share rplidar_ros)/launch/rplidar_a1_launch.py">
    <arg name="serial_port" value="/dev/ttyUSB0" />
    <arg name="auto_standby" value="true" />
  </include>

  <let name="xacro_file" value="$(find-pkg-share controller)/res/dora.xacro" />
  <let name="config_file" value="$(find-pkg-share controller)/res/dora_config.rviz" />
  <let name="urdf" value="$(command 'xacro $(var xacro_file)')" />

  <node pkg="joint_state_publisher" exec='joint_state_publisher'
    name='joint_state_publisher' namespace="dora">

    <param name="output" value="screen" />
    <param name="robot_description" value="$(var urdf)" />
  </node>

  <node pkg="robot_state_publisher" exec='robot_state_publisher'
    name='robot_state_publisher' namespace="dora">

    <param name="output" value="screen" />
    <param name="robot_description" value="$(var urdf)" />
    <param name="frame_prefix" value="dora/" />
  </node>

</launch>
