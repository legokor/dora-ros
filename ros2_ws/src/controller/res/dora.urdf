<?xml version="1.0"?>
<robot name="dora" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:property name="body_height" value="0.103" />
    <xacro:property name="body_to_floor" value="0.012" />

    <xacro:property name="axle_to_center_dist" value="0.18" />
    <xacro:property name="wheel_axle_length" value="0.025" />
    <xacro:property name="wheel_diameter" value="0.056" />
    <xacro:property name="wheel_width" value="0.023" />

    <xacro:property name="lidar_height" value="0.045" />

    <!-- TODO: make it work without internet access -->
    <xacro:property name="mesh_path"
        value="https://raw.githubusercontent.com/legokor/dora-ros/refs/heads/master/ros2_ws/src/controller/res/dora_vaz.stl" />

    <!-- TODO: scale down mesh in stl -->
    <xacro:property name="mesh_scale" value="0.001 0.001 0.001" />

    <link name="base_link">
        <visual>
            <origin xyz="0 0 ${body_to_floor + body_height / 2}" rpy="0 0 ${pi / 3}" />

            <geometry>
                <mesh filename="${mesh_path}" scale="${mesh_scale}" />
            </geometry>

            <material name="wood">
                <color rgba="0.96 0.73 0.53 1" />
            </material>
        </visual>

        <collision>
            <origin xyz="0 0 ${body_to_floor + body_height / 2}" rpy="0 0 ${pi / 3}" />

            <geometry>
                <mesh filename="${mesh_path}" scale="${mesh_scale}" />
            </geometry>
        </collision>
    </link>

    <link name="base_lidar"></link>
    <joint name="lidar_joint" type="fixed">
        <parent link="base_link" />
        <child link="base_lidar" />
        <origin xyz="0 0 ${body_to_floor + body_height + lidar_height}" />
    </joint>

    <xacro:macro name="omniwheel" params="idx">
        <xacro:property name="angle" value='${pi / 6 + 2 * pi * idx / 3}' />
        <xacro:property name="wheel_dist"
            value="${axle_to_center_dist + wheel_axle_length}" />

        <joint name="wheel_joint_${idx}" type="continuous">
            <parent link="base_link" />
            <child link="wheel_${idx}" />
            <origin
                xyz="${cos(angle) * wheel_dist} ${sin(angle) * wheel_dist} ${wheel_diameter / 2}"
                rpy="0 0 0"
            />
            <axis xyz="${cos(angle)} ${sin(angle)} 0" />
        </joint>

        <link name="wheel_${idx}">
            <collision>
                <origin rpy="${0.5 * pi} ${0.5 * pi} ${angle - 0.5 * pi}" />

                <geometry>
                    <cylinder radius="${wheel_diameter / 2}" length="${wheel_width}" />
                </geometry>
            </collision>

            <visual>
                <origin rpy="${0.5 * pi} ${0.5 * pi} ${angle - 0.5 * pi}" />

                <geometry>
                    <cylinder radius="${wheel_diameter / 2}" length="${wheel_width}" />
                </geometry>
            </visual>
        </link>
    </xacro:macro>

    <xacro:omniwheel idx="0" />
    <xacro:omniwheel idx="1" />
    <xacro:omniwheel idx="2" />
</robot>
